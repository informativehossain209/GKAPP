<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/splash_background"
    android:padding="40dp">

    <!-- App Logo — high-res drawable, crisp on all screens -->
    <ImageView
        android:id="@+id/splash_logo"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:src="@drawable/app_logo"
        android:scaleType="fitCenter"
        android:layout_marginBottom="8dp" />

    <!-- Tagline -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="আপনার সংসারের হিসাব"
        android:textSize="14sp"
        android:textColor="#AAFFFFFF"
        android:layout_marginBottom="8dp"
        android:gravity="center" />

    <!-- Divider line -->
    <View
        android:layout_width="80dp"
        android:layout_height="2dp"
        android:background="#FF6600"
        android:alpha="0.7"
        android:layout_marginBottom="40dp" />

    <!-- Spacer -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- "Developed by" label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Developed by"
        android:textSize="12sp"
        android:textColor="#88FFFFFF"
        android:letterSpacing="0.12"
        android:textAllCaps="true"
        android:layout_marginBottom="6dp"
        android:gravity="center" />

    <!-- DEVELOPER NAME -->
    <TextView
        android:id="@+id/splash_dev_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SAKIB HOSSAIN"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:letterSpacing="0.15"
        android:shadowColor="#FF8C00"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="18"
        android:gravity="center"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/splash_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Full Stack Developer"
        android:textSize="12sp"
        android:textColor="#88FFFFFF"
        android:letterSpacing="0.08"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

</LinearLayout>
