<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0A0A0A"
    android:padding="36dp">

    <!-- No-wifi icon -->
    <ImageView
        android:id="@+id/no_internet_icon"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:src="@drawable/ic_no_wifi"
        android:layout_marginBottom="28dp" />

    <!-- Bengali main title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ইন্টারনেট সংযোগ নেই"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#FF6600"
        android:shadowColor="#661A00"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="16"
        android:gravity="center"
        android:layout_marginBottom="14dp" />

    <!-- Bengali subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="লগইন করতে ইন্টারনেটের সাথে\nসংযুক্ত হন"
        android:textSize="16sp"
        android:textColor="#CCFFFFFF"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="10dp" />

    <!-- English subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Please connect to the internet to log in"
        android:textSize="12sp"
        android:textColor="#66FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="44dp" />

    <!-- Divider -->
    <View
        android:layout_width="60dp"
        android:layout_height="1dp"
        android:background="#33FF6600"
        android:layout_marginBottom="44dp" />

    <!-- Retry button -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/btn_retry_bg"
        android:id="@+id/btn_retry"
        android:clickable="true"
        android:focusable="true"
        android:paddingStart="36dp"
        android:paddingEnd="36dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↺  আবার চেষ্টা করুন"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.02" />

    </LinearLayout>

    <!-- Footer hint -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wi-Fi বা মোবাইল ডেটা চালু করুন"
        android:textSize="11sp"
        android:textColor="#44FFFFFF"
        android:gravity="center" />

</LinearLayout>
